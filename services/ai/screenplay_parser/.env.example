# FilmForge - Screenplay Parser Configuration
# Copy this to .env and fill in your values

# LLM Provider: "openai", "anthropic", or "mock" (mock = rule-based only, no API needed)
LLM_PROVIDER=mock

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8100

# LLM Model Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096